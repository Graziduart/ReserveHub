VITE_API_IAM=http://127.0.0.1:3001
VITE_API_CORE=http://127.0.0.1:3000
VITE_API_DATA=http://127.0.0.1:3002
VITE_API_AUDIT=http://127.0.0.1:3003

# Em dev, recomendado: evita CORS e usa os mesmos host/porta do Vite (5173).
# Com 1, as chamadas vão para /proxy/core, /proxy/iam, /proxy/data, /proxy/audit (ver vite.config.ts).
VITE_USE_PROXY=1

# Circuit breaker (fetch do front) — opcional
# VITE_CB_FAILURE_THRESHOLD=5
# VITE_CB_RESET_MS=30000
# VITE_CB_HALF_OPEN_SUCCESSES=1

# Google Sign-In
# VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com