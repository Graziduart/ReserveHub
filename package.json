{
  "name": "reservehub",
  "private": true,
  "description": "Orquestração local dos serviços ReserveHub",
  "scripts": {
    "start:backend": "node scripts/start-all.mjs --no-web",
    "start:backend:seed": "node scripts/start-all.mjs --no-web --seed",
    "start:all": "node scripts/start-all.mjs",
    "start:all:seed": "node scripts/start-all.mjs --seed",
    "start:all:full": "node scripts/start-all.mjs --seed --build --integration",
    "stop:all": "node scripts/stop-all.mjs",
    "docker:up": "docker compose --profile backend up -d --build",
    "rebuild:core": "node scripts/start-local-core.mjs",
    "docker:up:full": "docker compose --profile full up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "verify": "node scripts/verify-services.mjs",
    "smoke": "node scripts/smoke-integration.mjs",
    "reconcile:dashboard": "node scripts/reconcile-dashboard.mjs",
    "integration": "npm run verify && npm run smoke",
    "test:all": "npm run build --prefix service-core && npm run build --prefix service-iam && npm run build --prefix service-audit && npm run build --prefix service-data && npm run test --prefix service-core && npm run test --prefix service-iam && npm run test --prefix service-audit && npm run test --prefix service-data && npm run test:e2e --prefix service-core && npm run test:e2e --prefix service-iam && npm run test:e2e --prefix service-audit && npm run test:e2e --prefix service-data",
    "ci": "npm run test:all",
    "test:integration:db": "npm run test:e2e --prefix service-core -- --testPathPattern=integration",
    "dev:web": "npm run dev --prefix frontend",
    "open:web": "node -e \"require('child_process').exec(process.platform==='win32'?'start http://127.0.0.1:5173':'open http://127.0.0.1:5173')\"",
    "build:web": "npm run build --prefix frontend",
    "setup:db": "node scripts/setup-database.mjs",
    "seed:demo": "node scripts/setup-database.mjs",
    "dev:core": "npm run start:dev --prefix service-core",
    "dev:iam": "npm run start:dev --prefix service-iam",
    "dev:data": "npm run start:dev --prefix service-data",
    "dev:audit": "npm run start:dev --prefix service-audit"
  }
}
