# ReserveHub — variáveis de produção (copiar para .env por serviço)

# Obrigatório: mesmo valor em IAM, core, data, audit
JWT_SECRET=change-me-in-production-use-long-random-string

# Postgres
DATABASE_URL=postgresql://user:password@postgres:5432/reserveHub

# RabbitMQ
RABBITMQ_URL=amqp://user:password@rabbitmq:5672

# MongoDB (data + audit)
MONGODB_URI=mongodb://mongo:27017/reservehub_data
MONGODB_AUDIT_URI=mongodb://mongo:27017/reservehub_audit

# Frontend (build-time)
VITE_USE_PROXY=1
VITE_API_CORE=/api/core
VITE_API_IAM=/api/iam
VITE_API_DATA=/api/data
VITE_API_AUDIT=/api/audit

# Opcional
ENABLE_SWAGGER=0
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_DAYS=7
