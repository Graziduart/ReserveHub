PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reserveHub?schema=iam"

JWT_SECRET=reservehub-iam-docker-secret-change-me
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_DAYS=7

# Opcional: senha do admin criado por `npx prisma db seed` (padrão ReserveHub1!)
# SEED_ADMIN_PASSWORD=ReserveHub1!

# Gestor de identidade (Keycloak / OIDC) — ver docs/IDENTITY.md
# IDP_PROVIDER=keycloak
# IDP_ISSUER=https://auth.empresa.com/realms/reservehub
# IDP_JWKS_URI=https://auth.empresa.com/realms/reservehub/protocol/openid-connect/certs
# IDP_AUTHORIZATION_URL=https://auth.empresa.com/realms/reservehub/protocol/openid-connect/auth?client_id=reservehub-web&response_type=code&scope=openid%20profile%20email&redirect_uri=...
# IDP_PASSWORD_RESET_URL=https://auth.empresa.com/realms/reservehub/login-actions/reset-credentials

# Google Sign-In — ver docs/IDENTITY.md
# GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
# GOOGLE_ALLOWED_DOMAIN=empresa.com
